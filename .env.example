COMPOSE_PROJECT_NAME=fasa-social-dashboard

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=fasa_social
MYSQL_USER=fasa_social
MYSQL_PASSWORD=change_me_local_password
MYSQL_ROOT_PASSWORD=change_me_local_root_password

BACKEND_PORT=8000
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

ASSET_STORAGE_BACKEND=local
ASSET_STORAGE_PATH=/app/storage/assets
ASSET_PUBLIC_BASE_URL=http://localhost:8000/public/assets
ASSET_PUBLIC_VERIFY_BASE_URL=
ASSET_MAX_SIZE_MB=50
